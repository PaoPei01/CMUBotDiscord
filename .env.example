# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Discord application configuration
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INTERACTIONS_ENDPOINT_URL=

# Supabase client configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side-only Supabase configuration
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL database
DATABASE_URL=

# Admin MVP protection
ADMIN_PASSWORD=

# AI answer composer for retrieved verified context only
AI_PROVIDER=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=

# Knowledge import limits
KNOWLEDGE_IMPORT_MAX_BYTES=10485760

# Embeddings for semantic search scripts
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=
GEMINI_API_KEY=
