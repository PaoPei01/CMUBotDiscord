# Runtime
NODE_ENV=development
BOT_ENV=development
LOG_LEVEL=info

# Discord application configuration
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Supabase client configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side-only Supabase configuration
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL database
DATABASE_URL=

# Knowledge retrieval
KNOWLEDGE_MATCH_MIN_SCORE=
FULL_TEXT_SEARCH_ENABLED=false
VECTOR_SEARCH_ENABLED=false

# pgvector and embeddings, for the later vector search phase
EMBEDDING_PROVIDER=none
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# AI answer composer, for the later grounded-AI phase only
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=

